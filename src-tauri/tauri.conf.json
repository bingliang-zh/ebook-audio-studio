{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ebook Audio Studio",
  "version": "0.1.0",
  "identifier": "com.bingliangzh.ebookaudiostudio",
  "build": {
    "beforeDevCommand": "pnpm --filter client dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter client build",
    "frontendDist": "../client/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ebook Audio Studio",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

